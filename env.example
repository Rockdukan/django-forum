DEBUG=true
TEMPLATE_DEBUG=true

# В production обязательно замените.
SECRET_KEY=django-insecure-change-me

# Через запятую.
ALLOWED_HOSTS=127.0.0.1,localhost

# Через запятую. В dev можно оставить как есть.
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8050,http://localhost:8050

# ----- База данных -----
# Какой файл подключён — задаётся в core/settings/development.py (sqlite) или production.py (postgresql/mysql), а не переменной здесь.

# --- SQLite — только при core.settings.development (components/database/sqlite.py) ---
# Имя файла относительно корня проекта (каталог с manage.py):
DB_SQLITE_NAME=db.sqlite3
# Либо абсолютный путь к файлу (если задан, DB_SQLITE_NAME не используется):
# DB_SQLITE_PATH=/var/lib/forum/db.sqlite3

# --- PostgreSQL (components/database/postgresql.py) ---
# DB_POSTGRES_HOST=localhost
# DB_POSTGRES_PORT=5432
# DB_POSTGRES_NAME=forum
# DB_POSTGRES_USER=forum
# DB_POSTGRES_PASSWORD=
# DB_POSTGRES_CONN_MAX_AGE=600
# Опционально: require, verify-full, disable, …
# DB_POSTGRES_SSLMODE=

# --- MySQL (components/database/mysql.py) ---
# DB_MYSQL_HOST=localhost
# DB_MYSQL_PORT=3306
# DB_MYSQL_NAME=forum
# DB_MYSQL_USER=forum
# DB_MYSQL_PASSWORD=
# DB_MYSQL_CONN_MAX_AGE=600

# Поддерживаемые схемы в каркасе: locmemcache://, filecache:///tmp/django-cache, dbcache://django_cache
CACHE_URL=locmemcache://

# Redis (components/database/redis.py): кэш default + онлайн sorted set. Пусто — кэш из CACHE_URL, онлайн по БД.
REDIS_URL=
# Секунды «онлайн» в Redis; реже писать last_activity в БД; пул redis (0 = таймауты не задавать)
# FORUM_PRESENCE_TTL=900
# FORUM_LAST_ACTIVITY_DB_SYNC_SECONDS=300
# REDIS_CACHE_MAX_CONNECTIONS=50
# REDIS_CACHE_SOCKET_TIMEOUT_SEC=0
# REDIS_CACHE_SOCKET_CONNECT_TIMEOUT_SEC=0

# SMTP (production.py использует эти переменные)
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=webmaster@localhost
